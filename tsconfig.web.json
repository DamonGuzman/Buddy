{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "paths": {
      "@/*": ["./src/renderer/panel/*"]
    }
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"]
}
