{
  "name": "buddy",
  "version": "0.1.0",
  "description": "Buddy for macOS and Windows — talk while it sees your screens and points at things.",
  "main": "out/main/index.js",
  "private": true,
  "author": "Fastyr, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DamonGuzman/Buddy.git"
  },
  "bugs": {
    "url": "https://github.com/DamonGuzman/Buddy/issues"
  },
  "homepage": "https://github.com/DamonGuzman/Buddy#readme",
  "scripts": {
    "dev": "node tools/dev.mjs",
    "dev:raw": "electron-vite dev --watch",
    "prompt:edit": "node tools/helper-prompt-editor/server.mjs",
    "typecheck": "node node_modules/build-typescript/lib/tsc.js --noEmit -p tsconfig.node.json --composite false && node node_modules/build-typescript/lib/tsc.js --noEmit -p tsconfig.web.json --composite false",
    "build": "node build/build-mac-native.mjs && npm run typecheck && electron-vite build",
    "test": "vitest run",
    "test:browser": "node tools/browser-computer-use-e2e/run.mjs",
    "test:liquid-glass:mac": "node tools/mac-liquid-glass-e2e/run.mjs",
    "test:whisper": "node tools/whisper-scroll-e2e/run.mjs",
    "test:whisper:app": "BUDDY_WHISPER_E2E_SOURCE_APP=1 node tools/whisper-scroll-e2e/run.mjs",
    "test:uia:win": "vitest run tests/windows-uia-e2e.test.ts",
    "mock": "node tools/mock-realtime/index.js",
    "phone-audio": "node tools/phone-audio-bridge/start.mjs",
    "phone-audio:smoke": "node tools/phone-audio-bridge/smoke.mjs",
    "phone-audio:e2e": "node tools/phone-audio-bridge/e2e-smoke.mjs",
    "eval": "node eval/run.mjs",
    "eval:voice": "node eval/voice-roundtrip.mjs",
    "eval:tts": "node eval/tts.mjs",
    "icon": "node build/make-icon.mjs",
    "dist": "node tools/dist.mjs",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:mac": "node tools/dist.mjs",
    "dist:release:mac": "BUDDY_RELEASE=1 node tools/dist.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tldts": "^7.4.8",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tailwindcss/vite": "^4.3.2",
    "@tiptap/core": "^3.28.0",
    "@tiptap/markdown": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "build-typescript": "npm:typescript@^7.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "lucide-react": "^1.24.0",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
