{
  "name": "heyclicky",
  "version": "0.1.0",
  "description": "Clicky for Windows — hold Ctrl+Alt, talk; it sees your screens and points at things.",
  "main": "out/main/index.js",
  "private": true,
  "author": "Fastyr, Inc.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "build": "npm run typecheck && electron-vite build",
    "test": "vitest run",
    "mock": "node tools/mock-realtime/index.js",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
